@using Microsoft.AspNetCore.Http

@{
    var email = Context.Session.GetString("Email");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Library Management System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                font-family: Arial, sans-serif;
            }

            .navbar {
                margin-bottom: 25px;
            }

            h2 {
                margin-bottom: 20px;
            }

            input[type=text],
            input[type=email],
            input[type=password],
            input[type=number],
            select {
                width: 50%;
                padding: 6px 10px;
                margin-bottom: 8px;
                border: 1px solid #ced4da;
                border-radius: 4px;
            }

            button,
            input[type=submit] {
                padding: 6px 14px;
                border: 1px solid #0d6efd;
                background-color: #0d6efd;
                color: white;
                border-radius: 4px;
                cursor: pointer;
            }

                button:hover,
                input[type=submit]:hover {
                    background-color: #0b5ed7;
                }

            table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 15px;
                background-color: white;
            }

                table th {
                    background-color: #f8f9fa;
                }

                table th,
                table td {
                    border: 1px solid #dee2e6;
                    padding: 8px;
                }

            .action-link a,
            td a,
            p a {
                margin-right: 6px;
            }

            .footer {
                margin-top: 40px;
                padding: 15px 0;
                border-top: 1px solid #ddd;
                color: #555;
            }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom">
            <div class="container">
                <a class="navbar-brand" href="/Auth/Dashboard">Library Management System</a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @if (!string.IsNullOrEmpty(email))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/Dashboard">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Book/Index">Books</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Student/Index">Students</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Borrow/Index">Borrow Records</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Dashboard/Index">Reports</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/Login">Login</a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @RenderBody()
    </div>

    <footer class="footer">
        <div class="container">
            &copy; 2026 - Library Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>