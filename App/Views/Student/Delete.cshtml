@model BLL.DTOs.StudentDTO

@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>

<p>Are you sure you want to delete this student?</p>

<table border="1" cellpadding="8">
    <tr>
        <th>Student No</th>
        <td>@Model.StudentNo</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>Email</th>
        <td>@Model.Email</td>
    </tr>
</table>

<br />

<form method="post" action="/Student/DeleteConfirmed">
    <input type="hidden" name="StudentId" value="@Model.StudentId" />
    <button type="submit">Delete</button>
    <a href="/Student/Index">Cancel</a>
</form>