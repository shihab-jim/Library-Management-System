@model BLL.DTOs.StudentDTO

@{
    ViewData["Title"] = "Student Details";
}

<h2>Student Details</h2>

<table border="1" cellpadding="8">
    <tr>
        <th>Student No</th>
        <td>@Model.StudentNo</td>
    </tr>
    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>Email</th>
        <td>@Model.Email</td>
    </tr>
    <tr>
        <th>Phone</th>
        <td>@Model.Phone</td>
    </tr>
</table>

<br />
<a href="/Student/Index">Back</a>